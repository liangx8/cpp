{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "detail": "编译程序",
            "type": "shell",
            "command": "make",
            "args": ["expense"],
            "group": {
                "isDefault": true,"kind": "build"
            },
            "options": {"cwd": "${workspaceFolder}/build"},
            "presentation": {
                // Reveal the output only if unrecognized errors occur.
                "reveal": "silent"
            },
            // Use the standard MS compiler pattern to detect errors, warnings and infos
            "problemMatcher": "$gcc"
        },{
            "label": "clean",
            "type": "shell",
            "command":"make",
            "args": ["clean"],
            "presentation": {}
        },{
            "label": "debug-build",
            "type": "shell",
            "command":"make",
            "args": ["TARGET=uzip","OPTC=-g"],
            "presentation": {
                // Reveal the output only if unrecognized errors occur.
                "reveal": "silent"
            },
            // Use the standard MS compiler pattern to detect errors, warnings and infos
            "problemMatcher": "$gcc"

        }
    ]
}